{
  "name": "backrooms",
  "version": "1.0.0",
  "description": "First-person survival horror set in the Backrooms — Three.js / WebGL",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "pnpm run build && wrangler dev",
    "check": "tsc --noEmit",
    "deploy": "pnpm run build && wrangler deploy"
  },
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.44.0",
    "@types/three": "^0.184.1",
    "puppeteer": "^25.1.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "wrangler": "^4.110.0"
  }
}
